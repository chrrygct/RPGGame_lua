# ===== Unity 自动生成目录（必须忽略） =====
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# 资源构建产物（视需要保留；通常忽略）
[Aa]ssetBundles/
[Aa]ssetStoreTools*/

# ===== Visual Studio / Rider / VSCode 工程文件 =====
# 这些由 Unity 自动重新生成
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity 崩溃及日志
sysinfo.txt
*.stackdump

# 构建产物
*.apk
*.aab
*.unitypackage
*.app

# Visual Studio 缓存目录
.vs/

# Gradle 缓存
.gradle/

# Rider
.idea/

# JetBrains
*.iml

# macOS
.DS_Store

# Windows 系统垃圾
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Unity Hub temp
*.tmp

# Crashlytics 生成的文件
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# 临时自动生成的元数据
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa.meta
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa/*

# XLua 自动生成的 wrap 代码（按需保留，通常忽略并构建时生成）
# /Assets/XLua/Gen/

# 大文件（>100MB）应使用 Git LFS，不要直接提交
# 例如：*.exr / 大贴图 / 模型文件
